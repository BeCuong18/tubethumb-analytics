{
  "name": "tubethumb-analytics",
  "private": true,
  "version": "1.1.2",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on tcp:5174 && node scripts/start-electron.js\"",
    "electron:build": "vite build && electron-builder",
    "electron:publish": "vite build && electron-builder -p always"
  },
  "build": {
    "appId": "com.tubethumb.analytics",
    "productName": "TubeThumb Analytics",
    "directories": {
      "output": "dist_electron"
    },
    "win": {
      "target": "nsis",
      "icon": "public/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "BeCuong18",
        "repo": "tubethumb-analytics"
      }
    ]
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "firebase": "^12.9.0",
    "node-machine-id": "^1.1.12",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.1",
    "electron": "^40.4.0",
    "electron-builder": "^26.7.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wait-on": "^9.0.4"
  }
}